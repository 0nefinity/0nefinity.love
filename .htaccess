RewriteEngine On

# Heikle Dot-Ordner direkt blocken, bevor andere Rewrite-Regeln greifen
RewriteRule "(^|/)\.(git|ssh|vscode)(/|$)" - [F,L,NC]

# HTTPS erzwingen (funktioniert sowohl nativ als auch hinter nginx-Proxy)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# non-www -> www
RewriteCond %{HTTP_HOST} ^0nefinity\.love$ [NC]
RewriteRule ^ https://www.0nefinity.love%{REQUEST_URI} [R=301,L]

# Spezifische URL-Weiterleitungen (case-sensitive fixes)
RewriteCond %{REQUEST_URI} !^/buyPi$
RewriteRule ^buypi$ /buyPi [R=302,L,NC]
RewriteRule ^readme/?$ /README [R=302,L]

# Pi-Quadrat Weiterleitung
RewriteRule ^piquadrat/?$ /kreisausdingen?anzahl=4&radius=53&zoom=1.00&panX=0.00&panY=0.00&zeichen=pi(30) [R=302,L]

# Textdateien durch PHP-Viewer anzeigen (.punkt, .dot, und andere Text-Extensions)
# Nur wenn die Datei tatsächlich existiert
# NICHT bei fetch/XHR-Requests (für JavaScript-Apps die rohen Text brauchen)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} \.(punkt|dot|txt|md)$ [NC]
RewriteCond %{HTTP:X-Requested-With} !XMLHttpRequest
RewriteCond %{HTTP:Accept} !application/json
RewriteCond %{QUERY_STRING} !raw=1
RewriteRule ^(.+)$ /tools/weird-text-viewer.php [L]

# Nur wenn die Datei existiert UND der Request-Pfad keinen Punkt enthält
# Ausnahme: PHP-Dateien, HTML-Dateien und Verzeichnisse werden nicht umgeleitet
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} !\.php$
RewriteCond %{REQUEST_FILENAME} !\.html$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteRule ^(.+)$ /tools/weird-text-viewer.php [L]

# Clean URLs: Redirect .html und .md Endungen zu URLs ohne Endung
# WICHTIG: Query-String mit [QSA] Flag erhalten!
RewriteCond %{THE_REQUEST} ^GET\ /(.+)\.html(\?.*)?\ HTTP
RewriteRule ^(.+)\.html$ /$1 [R=302,L,QSA]

# Intern auf .html Dateien routen (wenn vorhanden)
# QSA: Query-String erhalten!
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# Intern auf .md Dateien routen (wenn vorhanden)
# QSA: Query-String erhalten!
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.md -f
RewriteRule ^(.+)$ $1.md [L,QSA]

# --- Color routes ---
# If the request is exactly one path segment (e.g. /black, /%23ff00aa) and it
# does not map to an existing file/dir or .html/.md, let tools/color.php decide.
# tools/color.php will return 200 for valid colors and 404 for invalid tokens.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.
RewriteRule ^([^/]+)/?$ /tools/color.php?c=$1 [L,QSA]

# Offenes Directory Listing (bewusst)
Options +Indexes
IndexOptions FancyIndexing NameWidth=* FoldersFirst
IndexOrderDefault Ascending Name
IndexIgnore .git .ssh .vscode .htaccess .htpasswd .env .env.* .gitignore .gitattributes .gitmodules

# Nur wirklich heikle Dotfiles sperren; Stil-Dotfiles wie .dot oder .punkt bleiben erlaubt
<FilesMatch "^\.((htaccess|htpasswd)|(env(\..*)?)|(gitignore|gitattributes|gitmodules))$">
  Require all denied
</FilesMatch>

# Performance
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/css application/javascript application/json image/svg+xml
</IfModule>